# Production Environment Variables Template
# Copy this file to .env and replace the values with your production settings.

# SECURITY WARNING: keep the secret key used in production secret!
# You can generate a new one using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=replace-me-with-a-secure-random-key

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=False

# PRODUCTION CONFIGURATION
# Set your backend domain/IP here (e.g., api.sentinel.com)
ALLOWED_HOSTS=api.sentinel.com,localhost,127.0.0.1

# Set your frontend Vercel domain here (e.g., https://sentinel.vercel.app)
CORS_ALLOWED_ORIGINS=https://sentinel.vercel.app,http://localhost:5173

# PostgreSQL Database Configuration
POSTGRES_DB=sentinel_db
POSTGRES_USER=bettercallok
POSTGRES_PASSWORD=your_secure_db_password
DATABASE_URL=postgres://bettercallok:your_secure_db_password@db:5432/sentinel_db
