# ============================================================================
# Sentinel — Production Environment Variables
# ============================================================================
# Copy this file to .env and replace the values with your production settings.

# ---- Django Core ----
# Generate a new key: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=replace-me-with-a-secure-random-key
DEBUG=False

# ---- Hosts & CORS ----
# Set your backend domain (e.g., sentinel-api.koyeb.app)
ALLOWED_HOSTS=sentinel-api.koyeb.app,localhost,127.0.0.1
# Set your frontend Vercel domain (e.g., https://sentinel.vercel.app)
CORS_ALLOWED_ORIGINS=https://sentinel.vercel.app,http://localhost:5173

# ---- Database (Neon PostgreSQL) ----
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/sentinel_db?sslmode=require

# ---- Cloudflare R2 Blob Storage ----
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
USE_S3=True
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
AWS_STORAGE_BUCKET_NAME=sentinel-vault
AWS_S3_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto

# ---- Solana RPC ----
# Free dedicated RPC from https://www.helius.dev/ or https://www.alchemy.com/solana
# Using a dedicated RPC avoids rate limits on the public endpoint
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key
